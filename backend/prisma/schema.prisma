// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model SellerUser {
  id            String      @id @default(uuid()) @db.Uuid
  storeName     String      @db.VarChar(25)
  phoneNumber   String      @unique @db.VarChar(20)

  state         String      @db.VarChar(50)
  county        String      @db.VarChar(50)
  town          String      @db.VarChar(50)
  platform      String      @db.VarChar(50)

  code String @unique @db.VarChar(7)

  complaints    Complaint[]

  createdAt     DateTime    @default(now()) @db.Timestamp(6)
  updatedAt     DateTime    @updatedAt @db.Timestamp(6)
}

model Complaint {
  id            String      @id @default(uuid()) @db.Uuid

  issues        String[]
  products      String[]

  barcode       String?     @db.VarChar(10)
  duration      String      @db.VarChar(50)
  distributor   String      @db.VarChar(50)

  imageUrl      String?      @db.Text
  details       String?     @db.VarChar(500)

  userId        String      @db.Uuid
  user          SellerUser        @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

model ConsumerUser {
  id            String      @id @default(uuid()) @db.Uuid
  companyName   String      @db.VarChar(50)
  companyProduct  String      @db.VarChar(50)

  state         String      @db.VarChar(50)
  county        String      @db.VarChar(50)
  town          String      @db.VarChar(50)

  imageUrl      String?      @db.Text
  details       String     @db.VarChar(500)

  name          String      @db.VarChar(20)
  phoneNumber   String      @unique @db.VarChar(25)
  email         String      @unique @db.VarChar(50)

  createdAt     DateTime    @default(now()) @db.Timestamp(6)
  updatedAt     DateTime    @updatedAt @db.Timestamp(6)
}

model Admin{
  id   String      @id @default(uuid()) @db.Uuid
  email String @unique
  password String @db.VarChar(255)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}